{
  "appId": "com.xilian.app",
  "appName": "Gaokao Reader",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "ios": {
    "contentInset": "automatic",
    "allowsLinkPreview": true,
    "scrollEnabled": true,
    "scheme": "GaokaoReader"
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": false,
    "webContentsDebuggingEnabled": false
  },
  "server": {
    "androidScheme": "https",
    "iosScheme": "https",
    "cleartext": true,
    "allowNavigation": ["api.deepseek.com", "dict.youdao.com"]
  }
}
